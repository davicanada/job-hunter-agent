# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_DATABASE_PASSWORD=
SUPABASE_ACCESS_TOKEN=

# LLM providers — the chain tries them in this order. Set at least one
# (GEMINI_API_KEY or GROQ_API_KEY) or the pipeline will refuse to start.

# Google Gemini (preferred first in the chain — generous free tier)
GEMINI_API_KEY=

# Groq (fast, ~100k TPD free tier; used as fallback)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (final fallback — free models routed through one API key)
OPENROUTER_API_KEY=

# Telegram (Block 4)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Behavior
MIN_SCORE_TO_NOTIFY=70
MAX_JOBS_PER_RUN=5
DRY_RUN=false
LOG_LEVEL=INFO

# (reserved for Block 4)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
